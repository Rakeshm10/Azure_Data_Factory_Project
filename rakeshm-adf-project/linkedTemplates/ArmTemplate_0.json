			"defaultValue": "rakesh"
		},
		"ls_data_lake_connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfrakeshmstorage.dfs.core.windows.net/"
		},
		"ls_github_properties_typeProperties_url": {
			"type": "string",
